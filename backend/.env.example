# Copy this file to backend/.env and fill in real values. Never commit backend/.env.

# Server
PORT=3000
TEST_MODE=true            # 'true' logs email codes to console instead of sending

# PostgreSQL
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mon_projet_extention

# Auth
JWT_SECRET=change_me_to_a_long_random_string

# Admin account (provisioned automatically at server startup).
# This is the ONLY way to create an admin — the extension registration panel
# always creates regular users. Leave blank to skip admin provisioning.
# The account is created (or updated) as is_admin=TRUE, verified, premium plan.
# Rotating ADMIN_PASSWORD here updates the password on next boot.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_to_a_strong_password

# Email (Gmail app password)
EMAIL_USER=
EMAIL_PASS=

# AI / TTS provider keys (server-side only — used by the backend proxy)
GEMINI_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=eleven_flash_v2_5   # optional; cheapest. or eleven_multilingual_v2
# Voices: FREE accounts can ONLY use ElevenLabs' CURRENT default voices (Aria, Sarah,
# Will, ...) — NOT Voice Library/community voices, NOT old defaults (Rachel/Arnold).
# Run `npm run voices:probe` to see which voice ids your key accepts.
# If a configured voice is blocked, the server auto-falls back to this one:
ELEVENLABS_FALLBACK_VOICE=9BWtsMINqrJLrRacOk9x
# Default + optional per-reader overrides (defaults are distinct current voices):
ELEVENLABS_DEFAULT_VOICE=9BWtsMINqrJLrRacOk9x
# ELEVENLABS_VOICE_AIKO=9BWtsMINqrJLrRacOk9x   # Aria
# ELEVENLABS_VOICE_MIRA=EXAVITQu4vr4xnSDxMaL   # Sarah
# ELEVENLABS_VOICE_KAI=bIHbv24MWmeRgasZH58o    # Will
# ELEVENLABS_VOICE_REN=nPczCjzI2devNBz1zQrb    # Brian
# ELEVENLABS_VOICE_NOVA=cgSgspJ2msm6clMCkdW9   # Jessica
# ELEVENLABS_VOICE_SAGE=JBFqnCBsd6RMkjVDRZzb   # George

# Gemini model + generation capabilities (all optional — defaults shown).
# Older models (gemini-pro, gemini-1.5-*) are retired. Run `npm run models:list`
# to see what your key supports.
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_VERSION=v1beta        # rarely needed; some models require v1
GEMINI_TEMPERATURE=0.7            # 0.0 = focused, 1.0+ = creative
GEMINI_MAX_OUTPUT_TOKENS=400     # max length of the AI response
# GEMINI_TOP_P=0.95              # optional nucleus sampling
# GEMINI_TOP_K=40               # optional top-k sampling

# Free plan: page reads allowed per day (0 = unlimited; set e.g. 10 to enforce a cap)
FREE_DAILY_READ_LIMIT=0

# Extension origin allowlist for CORS
ALLOWED_ORIGIN=chrome-extension://<EXTENSION_ID>

# Google OAuth client id (for account linking). Must match the manifest oauth2 client_id.
GOOGLE_CLIENT_ID=
